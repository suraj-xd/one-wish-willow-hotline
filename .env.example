# Pick the active provider. Keep both keys configured so production can switch
# by changing AI_PROVIDER and redeploying.
# Valid values: openrouter, deepseek
AI_PROVIDER=openrouter

# Option A — OpenRouter (any model on https://openrouter.ai/models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Option B — DeepSeek platform key (https://platform.deepseek.com)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Public production URL used for canonical links, sitemap, and social cards.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# local = unlimited wishes/messages (default in dev) · prod = limits on
# OWW_MODE=prod

# --- Rate limiting (all optional, defaults shown) ---
# OWW_MESSAGES_PER_DAY=80
# OWW_CHATS_PER_DAY=4
# OWW_BURST_PER_MINUTE=8
# OWW_GLOBAL_MESSAGES_PER_DAY=4000
# RATE_SALT=change-me

# Production-grade limiting across serverless instances (optional):
# create a free Upstash Redis db and set both — the limiter picks them up.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
